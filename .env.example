# Copy this file to .env.local for local development with `vercel dev`.
# NEVER put the real key in code or commit .env.local — it is git-ignored.
# In production, set this in: Vercel Dashboard → Settings → Environment Variables.

GROQ_API_KEY=your_new_groq_key_here
ELEVENLABS_API_KEY=your_new_elevenlabs_key_here
